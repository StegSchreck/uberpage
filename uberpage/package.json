{
  "name": "uberpage",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "author": "Sebastian Schreck",
  "private": true,
  "homepage": "https://stegschreck.github.io",
  "dependencies": {
    "eslint": "10.7.0",
    "eslint-plugin-react": "7.37.5",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "predeploy": "yarn run build",
    "deploy": "gh-pages -b master -d build -r git@github.com:StegSchreck/stegschreck.github.io.git"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "yarn@4.12.0"
}
